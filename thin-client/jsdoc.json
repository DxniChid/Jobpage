{
  "source": {
    "include": ["src"],
    "includePattern": ".+\\.js(doc|x)?$",
    "excludePattern": "(node_modules|docs|dist)"
  },
  "opts": {
    "destination": "./docs/api",
    "recurse": true,
    "template": "templates/default",
    "encoding": "utf8"
  },
  "plugins": [
    "plugins/markdown"
  ]
}